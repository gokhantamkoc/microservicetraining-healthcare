    {
      "name": "01 Tenant Service via Gateway REST",
      "item": [
        {
          "name": "Create Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('tenant created', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('tenantId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tenant A Clinic\",\n  \"location\": \"Istanbul\",\n  \"notificationProvider\": \"AWS_SNS\"\n}"
            },
            "url": "{{gatewayUrl}}/tenants"
