    {
      "name": "07 Direct GraphQL Examples",
      "item": [
        {
          "name": "Tenant GraphQL - List Tenants",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { tenants { id name location notificationProvider } }\"\n}"
            },
            "url": "{{tenantUrl}}/graphql"
          }
        },
        {
          "name": "Tenant GraphQL - Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($tenantId: ID!, $patientId: ID!, $physicianId: ID!, $startsAt: String!) { createAppointment(tenantId: $tenantId, patientId: $patientId, physicianId: $physicianId, startsAt: $startsAt) { id tenantId patientId physicianId startsAt status } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\",\n    \"patientId\": \"{{patientId}}\",\n    \"physicianId\": \"{{physicianId}}\",\n    \"startsAt\": \"2026-07-26T10:00:00Z\"\n  }\n}"
            },
            "url": "{{tenantUrl}}/graphql"
          }
        },
        {
          "name": "Tenant GraphQL - List Appointments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($tenantId: ID!) { appointments(tenantId: $tenantId) { id patientId physicianId startsAt status } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\"\n  }\n}"
            },
            "url": "{{tenantUrl}}/graphql"
          }
        },
        {
          "name": "Tenant GraphQL - Create Announcement",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($tenantId: ID!, $title: String!, $body: String!) { createAnnouncement(tenantId: $tenantId, title: $title, body: $body) { id tenantId title body publishedAt } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\",\n    \"title\": \"GraphQL announcement\",\n    \"body\": \"This announcement was created from Postman GraphQL.\"\n  }\n}"
            },
            "url": "{{tenantUrl}}/graphql"
          }
        },
        {
          "name": "Tenant GraphQL - List Announcements",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($tenantId: ID!) { announcements(tenantId: $tenantId) { id title body publishedAt } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\"\n  }\n}"
            },
            "url": "{{tenantUrl}}/graphql"
          }
        },
        {
          "name": "Patient GraphQL - List Patients",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($tenantId: ID!) { patients(tenantId: $tenantId) { id fullName medicalRecordNumber phoneNumber } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\"\n  }\n}"
            },
            "url": "{{patientUrl}}/graphql"
          }
        },
        {
          "name": "Patient GraphQL - Add Medical History",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($patientId: ID!, $summary: String!) { addMedicalHistoryEntry(patientId: $patientId, summary: $summary) { id patientId summary occurredAt } }\",\n  \"variables\": {\n    \"patientId\": \"{{patientId}}\",\n    \"summary\": \"GraphQL-created history entry from Postman\"\n  }\n}"
            },
            "url": "{{patientUrl}}/graphql"
          }
        },
        {
          "name": "Patient GraphQL - List Medical History",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($patientId: ID!) { medicalHistory(patientId: $patientId) { id summary occurredAt } }\",\n  \"variables\": {\n    \"patientId\": \"{{patientId}}\"\n  }\n}"
            },
            "url": "{{patientUrl}}/graphql"
          }
        },
        {
          "name": "Search GraphQL - Search History",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($tenantId: ID!, $term: String!) { searchPatientHistory(tenantId: $tenantId, term: $term) { id patientId summary occurredAt } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\",\n    \"term\": \"cardiology\"\n  }\n}"
            },
            "url": "{{searchUrl}}/graphql"
          }
        },
        {
          "name": "Checkout GraphQL - Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($id: ID!) { checkoutStatus(id: $id) { id tenantId patientId amount status } }\",\n  \"variables\": {\n    \"id\": \"{{checkoutSessionId}}\"\n  }\n}"
            },
            "url": "{{checkoutUrl}}/graphql"
          }
        },
        {
          "name": "Notification GraphQL - Deliveries",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query($tenantId: ID!) { notifications(tenantId: $tenantId) { id patientId provider message deliveredAt } }\",\n  \"variables\": {\n    \"tenantId\": \"{{tenantId}}\"\n  }\n}"
            },
            "url": "{{notificationUrl}}/graphql"
          }
        }
      ]
    }
  ]
